# Razum AI — Настройки

# === GPU-сервер (обязательно) ===
# URL вашего vLLM / Ollama / OpenAI-совместимого сервера
INFERENCE_URL=http://localhost:11434/v1

# API-ключ (если требуется сервером)
INFERENCE_API_KEY=not-needed

# === Модели ===
# Имена моделей на вашем inference-сервере
MODEL_LLAMA=llama3:70b
MODEL_MISTRAL=mistral:7b
MODEL_QWEN=qwen2.5:72b
