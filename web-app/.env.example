# Razum AI — Environment Variables
# Copy to .env.local for development or .env for production

# ============ REQUIRED ============

# Authentication secret (generate: openssl rand -hex 64)
AUTH_SECRET=

# Node environment
NODE_ENV=development

# ============ INFERENCE ============

# GPU server URL (Ollama / vLLM / OpenAI-compatible)
INFERENCE_URL=http://localhost:11434/v1

# API key (if required by your inference server)
INFERENCE_API_KEY=not-needed

# Model names on your inference server
MODEL_DEEPSEEK=deepseek-r1:14b
MODEL_MISTRAL=mistral:7b

# ============ SEARCH (optional) ============

# Brave Search API (free 2000 queries/month)
# Get key at: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# SearXNG self-hosted instance (alternative to Brave)
# SEARXNG_URL=https://your-searxng-instance.com

# ============ PAYMENTS (optional) ============

# Robokassa (without these, dev mode auto-activates plans)
# Get credentials at: https://partner.robokassa.ru
ROBOKASSA_LOGIN=
ROBOKASSA_PASS1=
ROBOKASSA_PASS2=
ROBOKASSA_TEST=true

# ============ EMAIL (optional) ============

# SMTP (without these, emails are logged to console)
# Yandex: smtp.yandex.ru:465 | Gmail: smtp.gmail.com:465
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ============ ANALYTICS (optional) ============

# Yandex.Metrika counter ID
# Create at: https://metrika.yandex.ru
NEXT_PUBLIC_YM_ID=

# ============ APP ============

# Public URL (for payment redirects, SEO)
NEXT_PUBLIC_URL=https://airazum.com

# Database directory (default: ./data)
# DATA_DIR=./data
