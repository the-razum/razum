# ===========================================
#  Razum AI Miner Configuration
# ===========================================

# ОБЯЗАТЕЛЬНО: Ваш Ethereum-кошелёк (MetaMask)
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Имя майнера (отображается в сети)
MINER_NAME=my-razum-miner

# Модель для скачивания (по умолчанию deepseek-r1:14b)
# Рекомендации по VRAM:
#   8GB  → mistral:7b или qwen2.5:7b
#   16GB → deepseek-r1:14b
#   24GB → deepseek-r1:32b
#   48GB → llama3:70b
OLLAMA_MODEL=deepseek-r1:14b

# Координатор (не меняй)
COORDINATOR=https://airazum.com

# GPU модель (для статистики)
GPU_MODEL=NVIDIA Docker

# Модели для поддержки (пусто = автоопределение)
MODELS=

# Интервалы (мс)
POLL_INTERVAL=2000
HEARTBEAT_INTERVAL=20000
